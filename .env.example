# .env.example — copy to .env and fill in your values.
# This file is safe to commit. .env is not (it holds real secrets).
#
# Active services that read this file: chat-agent, mcp-server.
# Legacy services (policy-engine, gateway, agent-executor) are not used.

# ── LLM backend ──────────────────────────────────────────────────────────────
# "ollama" = fully local, no cloud calls.
# "openai_compatible" = any OpenAI-compatible API (DeepSeek, GitHub Models, etc.)
LLM_PROVIDER=ollama
OLLAMA_CHAT_MODEL=llama3

# Only needed when LLM_PROVIDER=openai_compatible:
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_API_KEY=your_key_here
# OPENAI_MODEL=deepseek-chat
# OPENAI_PROVIDER_LABEL=DeepSeek

# ── Embeddings (always local Ollama) ─────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Vector database ───────────────────────────────────────────────────────────
# When running chat-agent locally (uvicorn): http://localhost:6333
# When running inside Docker Compose: http://qdrant:6333  (set in docker-compose.yml)
QDRANT_URL=http://localhost:6333

# ── PM integrations (read by mcp-server, not by chat-agent) ──────────────────
# Leave blank if you don't use Jira/GitHub sync.
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your_jira_api_token

GITHUB_TOKEN=your_github_pat

# ── Optional ──────────────────────────────────────────────────────────────────
# BRAVE_SEARCH_API_KEY=your_brave_key   # enables web search tool in mcp-server
# MCP_BASE_URL=http://localhost:8083    # default; override if mcp-server runs elsewhere
